{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "preserve",                  // ✅ Enables JSX
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["DOM", "ESNext"],
    "moduleResolution": "Node",
    "esModuleInterop": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true
  },
  "include": ["**/*.ts", "**/*.tsx"],   // ✅ Includes .tsx files
  "exclude": ["node_modules"]
}
